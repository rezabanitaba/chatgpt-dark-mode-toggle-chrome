{
  "manifest_version": 3,
  "name": "ChatGPT Dark Mode Toggle",
  "version": "1.0",
  "description": "One-click dark/light mode toggle for ChatGPT with a moon icon in the sidebar.",
  "permissions": ["scripting", "storage"],
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
